<Window x:Class="WPFZooManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFZooManager"
        mc:Ignorable="d"
        Title="Zoo Manager" Height="400" Width="510">
    <Grid>
        <Label Content="Zoo List" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
        <ListBox Name="listZoos"
                 Height="203"
                 Width="150"
                 Margin="10,41,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top" SelectionChanged="listZoos_SelectionChanged"/>
        <Label Content="Associated Animal List" HorizontalAlignment="Left" Margin="180,10,0,0" VerticalAlignment="Top"/>
        <ListBox x:Name="listAssociatedAnimals"
            Height="203"
            Width="150"
            Margin="180,41,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"/>
        <ListBox x:Name="listAnimals"
            Height="249"
            Width="150"
            Margin="351,41,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"/>
        <Button Content="Delete Zoo" 
                HorizontalAlignment="Left" 
                Margin="10,249,0,0" 
                VerticalAlignment="Top" Width="150" Click="DeleteZoo_Clicked"/>
        <Button Content="Remove Animal from Zoo" 
            HorizontalAlignment="Left" 
            Margin="180,249,0,0" 
            VerticalAlignment="Top" Width="150" Click="RemoveAnimalFromZoo_Click"/>
        <Button Content="Add Zoo" 
            HorizontalAlignment="Left" 
            Margin="10,325,0,0" 
            VerticalAlignment="Top" Width="150" Click="AddZoo_Clicked"/>
        <Button Content="Update Zoo" 
            HorizontalAlignment="Left" 
            Margin="10,350,0,0" 
            VerticalAlignment="Top" Width="150"/>
        <Button Content="Add Animal" 
            HorizontalAlignment="Left" 
            Margin="351,13,0,0" 
            VerticalAlignment="Top" Width="150" Click="AddAnimal_Clicked"/>
        <Button Content="Update Animal" 
            HorizontalAlignment="Left" 
            Margin="180,349,0,0" 
            VerticalAlignment="Top" Width="150"/>
        <Button Content="Delete Animal" 
            HorizontalAlignment="Left" 
            Margin="351,349,0,0" 
            VerticalAlignment="Top" Width="150" Click="DeleteAnimal_Clicked"/>
        <Button Content="Add Animal to Zoo" 
            HorizontalAlignment="Center" 
            Margin="0,324,0,0" 
            VerticalAlignment="Top" Width="150" Click="AddAnimailToZoo_Clicked"/>
        <TextBox Name="zooTextBox"
                 HorizontalAlignment="Left" 
                 Margin="10,274,0,0" 
                 TextWrapping="Wrap" 
                 Text="New Zoo Location"
                 VerticalAlignment="Top" 
                 Width="320" Height="46"/>
        <TextBox x:Name="animalTextBox"
            HorizontalAlignment="Left" 
            Margin="351,297,0,0" 
            TextWrapping="Wrap" 
            Text="New Animal"
            VerticalAlignment="Top" 
            Width="150" Height="46"/>

    </Grid>
</Window>
